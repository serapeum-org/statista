{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(*)",
            "Read(*)",
            "Write(*)",
            "Edit(*)",
            "Glob(*)",
            "Grep(*)",
            "WebSearch",
            "WebFetch(*)",
            "Skill(*)",
            "Agent(*)",
            "WebFetch"
        ],
        "deny": [
            "Bash(gh pr merge:*)",
            "Bash(git merge:*)",
            "Bash(git push --force:*)",
            "Bash(git reset --hard:*)"
        ]
    }
}
