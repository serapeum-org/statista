@startuml TimeSeries Class Diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageFontSize 13

package "pandas" {
    class DataFrame
}

package "statista.time_series" {

    class TimeSeriesBase {
        {static} _get_ax_fig()
        {static} _adjust_axes_labels()
    }

    class DescriptiveMixin {
        +stats : DataFrame
        +extended_stats : DataFrame
        +l_moments(nmom) : DataFrame
        +summary() : DataFrame
    }

    class VisualizationMixin {
        +box_plot()
        +violin()
        +raincloud()
        +histogram()
        +density()
        +rolling_statistics()
        {static} +calculate_whiskers()
    }

    class MissingDataMixin {
        +missing_summary() : DataFrame
        +gap_analysis() : DataFrame
        +completeness_report() : DataFrame
        +detect_outliers() : DataFrame
        +outlier_plot()
    }

    class CorrelationMixin {
        +acf()
        +pacf()
        +cross_correlation()
        +lag_plot()
        +correlation_matrix()
        +ljung_box() : DataFrame
    }

    class StationarityMixin {
        +adf_test() : DataFrame
        +kpss_test() : DataFrame
        +stationarity_summary() : DataFrame
    }

    class TrendMixin {
        +mann_kendall() : DataFrame
        +sens_slope() : DataFrame
        +detrend() : TimeSeries
        +innovative_trend_analysis()
    }

    class DistributionMixin {
        +qq_plot()
        +pp_plot()
        +normality_test() : DataFrame
        +empirical_cdf()
        +fit_distributions() : DataFrame
    }

    class ChangePointMixin {
        +pettitt_test() : DataFrame
        +snht_test() : DataFrame
        +buishand_range_test() : DataFrame
        +cusum()
        +homogeneity_summary() : DataFrame
    }

    class DecompositionMixin {
        +classical_decompose()
        +smooth() : TimeSeries
        +envelope()
    }

    class SeasonalMixin {
        +monthly_stats() : DataFrame
        +seasonal_subseries()
        +annual_cycle()
        +periodogram()
        +seasonal_mann_kendall() : DataFrame
    }

    class HydrologicalMixin {
        +flow_duration_curve()
        +annual_extremes() : TimeSeries
        +exceedance_probability() : DataFrame
        +baseflow_separation()
        +baseflow_index() : DataFrame
        +flashiness_index() : DataFrame
        +recession_analysis()
    }

    class ComparisonMixin {
        +anomaly()
        +standardized_anomaly() : TimeSeries
        +double_mass_curve()
        +regime_comparison() : DataFrame
    }

    class TimeSeries {
        +_constructor : type
    }
}

package "statista.stat_result" {
    class StatTestResult <<frozen>>
    class TrendTestResult <<frozen>>
    class ChangePointResult <<frozen>>
}

DataFrame <|-- TimeSeriesBase
TimeSeriesBase <|-- TimeSeries
DescriptiveMixin <|-- TimeSeries
VisualizationMixin <|-- TimeSeries
MissingDataMixin <|-- TimeSeries
CorrelationMixin <|-- TimeSeries
StationarityMixin <|-- TimeSeries
TrendMixin <|-- TimeSeries
DistributionMixin <|-- TimeSeries
ChangePointMixin <|-- TimeSeries
DecompositionMixin <|-- TimeSeries
SeasonalMixin <|-- TimeSeries
HydrologicalMixin <|-- TimeSeries
ComparisonMixin <|-- TimeSeries

@enduml
